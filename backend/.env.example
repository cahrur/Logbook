# ===== APP =====
NODE_ENV=development
APP_PORT=8000

# Comma-separated allowed origins for CORS (frontend dev server, prod domain)
CORS_ORIGINS=http://localhost:5173

# ===== DATABASE (key-value) =====
# DB_CLIENT: "pg" for PostgreSQL (port 5432) or "mysql2" for MySQL (port 3306)
DB_CLIENT=pg
DB_HOST=localhost
DB_PORT=5432
DB_NAME=logbook
DB_USER=postgres
DB_PASS=postgres

# ===== AUTH / JWT =====
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ISSUER=logbook-auth
JWT_AUDIENCE=logbook-client
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8

# ===== RATE LIMIT =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=10

# ===== CLOUDFLARE TURNSTILE (captcha login) =====
# Kosongkan di lokal untuk skip verifikasi. Set keduanya di production.
# Testing keys (selalu lolos): secret 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=
TURNSTILE_EXPECTED_HOSTNAME=

# ===== FILE UPLOAD (PDF berkas modul) =====
# In production (Coolify), point UPLOAD_DIR to a mounted persistent volume,
# otherwise uploaded files are lost on redeploy.
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ===== INITIAL ADMIN (seeded on first boot when no users exist) =====
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234

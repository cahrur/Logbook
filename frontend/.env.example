# API base URL. In dev this is proxied to the backend by Vite, so the
# relative default works for both dev and the single-resource production build.
VITE_API_BASE_URL=/api/v1

# Dev-only: where Vite proxies /api to (your local backend).
VITE_DEV_API_TARGET=http://localhost:8000

# Cloudflare Turnstile site key (public). Kosong = pakai testing key (selalu lolos).
# Set ini saat BUILD untuk production (Vite membakukan env saat build).
VITE_TURNSTILE_SITE_KEY=
